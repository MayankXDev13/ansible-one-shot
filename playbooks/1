- name: Install Packages
  hosts: servers
  become: yes

  vars:
    packages_to_install:
      - tree
      - zip
      - unzip
      - jq
      - wget
      - apache2
  tasks:
    - name: Install Package
      apt: 
        name: "{{item}}"
        state: present
      loop: "{{ packages_to_install }}" # loop the list
      when: ansible_fact["distribution"] == "Ubuntu" # condition
    - name: Show Message
      loop: "{{ packages_to_install }}" # loop the list
      debug:
        msg: "Installing {{ item }}" # access the item 
       when: ansible_fact["distribution"] == "Ubuntu" # condition
